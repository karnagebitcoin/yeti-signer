{
	"manifest_version": 2,
	"name": "Yeti",
	"version": "1.6.1",
	"description": "A coooool nostr signer",
	"browser_action": {
		"default_popup": "popup.html"
	},
	"icons": {
		"16": "assets/logo-on.png",
		"32": "assets/logo-on.png",
		"48": "assets/logo-on-64.png",
		"128": "assets/logo-on-128.png"
	},
	"background": {
		"scripts": ["background.js"],
		"type": "module"
	},
	"permissions": ["storage", "tabs", "http://*/*", "https://*/*"],
	"content_scripts": [
		{
			"matches": ["http://*/*", "https://*/*"],
			"js": ["content.js"],
			"run_at": "document_start"
		}
	],
	"web_accessible_resources": ["assets/nostr-provider.js"],
	"browser_specific_settings": {
		"gecko": {
			"id": "keys-band@toastr.space",
			"strict_min_version": "109.0"
		}
	}
}
